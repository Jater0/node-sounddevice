{
  "name": "node-sounddevice",
  "version": "0.1.0",
  "description": "Play and Record Sound with Node.js / Electron / Browser — TypeScript port of python-sounddevice",
  "license": "MIT",
  "keywords": ["sound", "audio", "PortAudio", "play", "record", "web-audio", "electron"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./portaudio": {
      "import": "./dist/backends/portaudio/index.mjs",
      "require": "./dist/backends/portaudio/index.js",
      "types": "./dist/backends/portaudio/index.d.ts"
    },
    "./web": {
      "import": "./dist/backends/web/index.mjs",
      "require": "./dist/backends/web/index.js",
      "types": "./dist/backends/web/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "backends/portaudio/native/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:native": "cd backends/portaudio/native && npm run build",
    "test": "vitest",
    "test:node": "vitest --environment node",
    "test:web": "vitest --environment jsdom",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
